{
  "name": "mqtt2pg",
  "version": "0.0.1",
  "description": "Forward MQTT messages to PostgreSQL (Proof of Concept)",
  "author": "Matthieu Aubry",
  "license": "MIT",
  "main": "dist/main.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
